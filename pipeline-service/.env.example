# ========================================
# Novel-to-Script Pipeline Configuration
# ========================================
# Copy this file to .env and fill in your values.
# .env is git-ignored — never commit real keys.

# --- LLM Configuration ---
# Model identifier for LiteLLM (e.g., "openai/gpt-4o", "deepseek/deepseek-chat")
LITELLM_MODEL=openai/mimo-v2.5-pro

# --- MiMo API (Xiaomi) ---
# Base URL for the MiMo API
MIMO_BASE_URL=https://token-plan-cn.xiaomimimo.com/v1
# Your MiMo API key
MIMO_API_KEY=your-mimo-api-key-here

# --- OpenAI API (optional) ---
# OPENAI_API_KEY=sk-...

# --- DeepSeek API (optional) ---
# DEEPSEEK_API_KEY=sk-...

# --- gRPC Auth Service ---
GRPC_AUTH_HOST=localhost
GRPC_AUTH_PORT=9090

# --- CORS ---
# Comma-separated list of allowed origins (use * for development)
CORS_ORIGINS=*
